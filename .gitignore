install_manifest.txt
Testing/
CTestTestfile.cmake

# Editors / IDEs
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.DS_Store

# Python (for future bindings)
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
.venv/
venv/

# Rust (for future Iceoryx2 native crate)
target/
Cargo.lock

# Profiling / traces
perf.data
perf.data.old
*.trace
*.svg.flamegraph

# Spike PoC runtime sockets / temp files
/tmp/axon_*
spike-runs/
